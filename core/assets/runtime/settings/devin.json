{
  "_agent_harness_deploy_note": "Auto-generated by Agent Harness Deploy. Merges with existing config. Devin uses Claude Code-compatible hooks format (PascalCase event names, nested matcher/hooks arrays). See https://docs.devin.ai/cli/extensibility/hooks/overview",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "exec",
        "hooks": [
          {
            "type": "command",
            "command": "python .devin/hooks/pre_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .devin/hooks/post_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],
    "AgentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .devin/hooks/stop.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python scripts/*)"
    ],
    "ask": [],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(curl * | bash:*)",
      "Bash(mkfs:*)"
    ]
  }
}
